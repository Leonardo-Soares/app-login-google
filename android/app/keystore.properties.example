# Copie este arquivo para keystore.properties (mesma pasta: android/app/).
# keystore.properties está no .gitignore — não commite senhas nem o arquivo real.
#
# Pré-requisitos para gerar o AAB na linha de comando:
# - JDK 17+ no PATH
# - ANDROID_HOME ou ANDROID_SDK_ROOT apontando para o Android SDK
# - Keystore (.p12 ou .jks) acessível; storeFile é relativo a android/app/
#
# Gerar o AAB (na raiz do projeto):
#   npm run android:bundle
#   (opcional, build limpo) npm run android:bundle:clean
#
# Saída:
#   android/app/build/outputs/bundle/release/app-release.aab
#
# Se keystore.properties não existir, o release usa assinatura debug (não use na Play Store).

storePassword=sua_senha_do_keystore
keyPassword=sua_senha_da_chave
keyAlias=seu_alias
# Exemplos: discontapp.p12 | chave.p12 (arquivo dentro de android/app/)
storeFile=chave.p12
